{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_MODEL": "claude-sonnet-4-6"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/kanna/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "/home/kanna/.claude/hooks/format-on-edit.sh 2>/dev/null || true",
            "statusMessage": "Formatting edited file"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "andrej-karpathy-skills@multica-ai": true
  },
  "effortLevel": "medium",
  "skipDangerousModePermissionPrompt": true
}
